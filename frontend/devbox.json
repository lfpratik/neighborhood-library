{
  "packages": [
    "nodejs@20",
    "gnumake@latest"
  ],
  "shell": {
    "init_hook": [
      "echo 'Frontend — Neighborhood Library'",
      "if [ ! -d node_modules ]; then echo 'Installing deps...'; make install; fi",
      "echo ''",
      "echo 'Ready! Run: make dev'"
    ],
    "scripts": {
      "start": "make dev",
      "build": "make build",
      "typecheck": "make typecheck",
      "clean": "make clean",
      "clean-all": "make clean-all"
    }
  }
}
